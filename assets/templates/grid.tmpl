{{define "grid"}}
<div class="panel">
  <div class="panel-head">
    <div>
      <h2 class="panel-title">{{.Title}}</h2>
      {{if .Description}}<p class="panel-copy">{{.Description}}</p>{{end}}
    </div>
    <div class="actions-row">
      {{if not .DisableRefresh}}
      <button class="btn btn-ghost btn-icon" onclick="location.reload()" title="Refresh">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
      </button>
      {{end}}
      {{range .Tools}}
        {{safeHTML .HTML}}
      {{end}}
      {{if .Actions}}
      {{range .Actions}}
        {{if eq .Method "GET"}}
        <a class="btn {{if $.ToolsWithOutline}}btn-outline-primary{{else}}btn-primary{{end}}" href="{{.URL}}" {{if $.EnableDialogCreate}}{{if eq .Label "Create"}}data-dialog="true" data-dialog-width="{{$.DialogWidth}}" data-dialog-height="{{$.DialogHeight}}"{{end}}{{end}}>
          {{if eq .Label "Create"}}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          {{end}}
          {{.Label}}
        </a>
        {{else}}
        <form method="post" action="{{.URL}}" onsubmit="{{if .Confirm}}return confirm('{{.Confirm}}'){{else}}return true{{end}}" style="display: inline;">
          {{if ne .Method "POST"}}<input type="hidden" name="_method" value="{{.Method}}">{{end}}
          <input type="hidden" name="_csrf" value="{{$.CSRF}}">
          <button class="btn btn-secondary" type="submit">
            {{if eq .Label "Export"}}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {{end}}
            {{.Label}}
          </button>
        </form>
        {{end}}
      {{end}}
      {{end}}
    </div>
  </div>

  <form class="toolbar" method="get" action="{{.CurrentPath}}">
    <div class="toolbar-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="search" name="q" value="{{.QuickSearch}}" placeholder="Search...">
    </div>
    {{if .Filters}}
    <div class="toolbar-filters">
      {{range .Filters}}
        {{if eq .Kind "select"}}
        <div class="toolbar-filter">
          <select name="{{.InputKey}}">
            <option value="">{{.Label}}</option>
            {{range .Options}}
            <option value="{{.Value}}" {{if .Selected}}selected{{end}}>{{.Label}}</option>
            {{end}}
          </select>
        </div>
        {{else}}
        <div class="toolbar-filter">
          <input type="text" name="{{.InputKey}}" value="{{.Value}}" placeholder="{{.Label}}">
        </div>
        {{end}}
      {{end}}
      <button class="btn btn-secondary btn-sm" type="submit">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
        Apply
      </button>
    </div>
    {{end}}
    {{if .PerPageOptions}}
    <div class="toolbar-perpage">
      <select name="per_page" onchange="this.form.submit()">
        {{range .PerPageOptions}}
        <option value="{{.}}" {{if eq . $.CurrentPerPage}}selected{{end}}>{{.}} / page</option>
        {{end}}
      </select>
    </div>
    {{end}}
  </form>

  {{if .BatchActions}}
  <div class="batch-actions" id="batchActions" style="display: none;">
    <span class="batch-selected-count">Selected <strong>0</strong> items</span>
    <div class="batch-actions-buttons">
      {{range .BatchActions}}
      <form method="post" action="{{.URL}}" class="batch-action-form" data-ajax="true" data-confirm="{{.Confirm}}" style="display: inline;">
        <input type="hidden" name="_csrf" value="{{$.CSRF}}">
        <input type="hidden" name="_ids" value="" class="batch-ids-input">
        <button class="btn {{.Class}}" type="submit">{{.Label}}</button>
      </form>
      {{end}}
    </div>
  </div>
  {{end}}

  <div class="table-wrap{{if .ScrollbarX}} scrollbar-x{{end}}">
    <table class="admin-table{{range .TableClasses}} {{.}}{{end}}">
      <thead>
        <tr>
          {{if .RowSelector.Enabled}}
          <th class="col-checkbox">
            <input type="checkbox" class="select-all-checkbox" title="Select all">
          </th>
          {{end}}
          {{range .Columns}}
          <th>
            {{if .Sortable}}
            <a href="{{.SortURL}}">
              {{.Label}}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m7 15 5 5 5-5"/>
                <path d="m7 9 5-5 5 5"/>
              </svg>
            </a>
            {{else}}
            {{.Label}}
            {{end}}
          </th>
          {{end}}
          <th class="col-actions" style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{if .Rows}}
        {{range .Rows}}
        <tr {{if $.RowSelector.Click}}data-click-select="true"{{end}}>
          {{if $.RowSelector.Enabled}}
          <td class="col-checkbox">
            <input type="checkbox" class="row-checkbox" value="{{.ID}}" {{if .Checked}}checked{{end}} {{if .Disabled}}disabled{{end}}>
          </td>
          {{end}}
          {{range .Cells}}
          <td>{{safeHTML .}}</td>
          {{end}}
          <td class="actions">
            {{if .Actions}}
              {{range .Actions}}
                {{if eq .Method "GET"}}
                <a href="{{.URL}}" {{if and $.EnableDialogEdit (eq .Label "Edit")}}data-dialog="true" data-dialog-width="{{$.DialogWidth}}" data-dialog-height="{{$.DialogHeight}}"{{end}}>
                  {{if eq .Label "View"}}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  {{else if eq .Label "Edit"}}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
                  </svg>
                  {{end}}
                  {{.Label}}
                </a>
                {{else}}
                <form method="post" action="{{.URL}}" onsubmit="{{if .Confirm}}return confirm('{{.Confirm}}'){{else}}return true{{end}}" style="display: inline;">
                  {{if ne .Method "POST"}}<input type="hidden" name="_method" value="{{.Method}}">{{end}}
                  <input type="hidden" name="_csrf" value="{{$.CSRF}}">
                  <button type="submit">
                    {{if eq .Label "Delete"}}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                    {{end}}
                    {{.Label}}
                  </button>
                </form>
                {{end}}
              {{end}}
            {{else}}
            <span style="color: var(--color-text-muted);">—</span>
            {{end}}
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="{{.ColSpan}}">
            <div class="empty">
              <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
              </svg>
              <div class="empty-title">No records found</div>
              <div class="empty-text">{{.EmptyText}}</div>
            </div>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>

  {{if .Rows}}
  <div class="panel-foot">
    <span style="color: var(--color-text-secondary); font-size: 0.875rem;">{{.ResultSummary}}</span>
    <div class="pagination">
      {{range .Pagination}}
      <a class="page-link {{if .Current}}is-current{{end}} {{if .Disabled}}is-disabled{{end}}" href="{{.URL}}">{{.Label}}</a>
      {{end}}
    </div>
  </div>
  {{end}}
</div>

{{if .RowSelector.Enabled}}
<script>
(function() {
  const table = document.querySelector('.admin-table');
  const selectAllCheckbox = table.querySelector('.select-all-checkbox');
  const rowCheckboxes = table.querySelectorAll('.row-checkbox');
  const batchActions = document.getElementById('batchActions');
  const batchIdsInput = batchActions ? batchActions.querySelectorAll('.batch-ids-input') : [];
  const batchCountSpan = batchActions ? batchActions.querySelector('.batch-selected-count strong') : null;

  function updateBatchActions() {
    const selected = table.querySelectorAll('.row-checkbox:checked');
    const ids = Array.from(selected).map(cb => cb.value);

    if (batchActions) {
      batchActions.style.display = ids.length > 0 ? 'flex' : 'none';
    }
    if (batchCountSpan) {
      batchCountSpan.textContent = ids.length;
    }
    batchIdsInput.forEach(input => {
      input.value = ids.join(',');
    });
  }

  if (selectAllCheckbox) {
    selectAllCheckbox.addEventListener('change', function() {
      rowCheckboxes.forEach(cb => {
        if (!cb.disabled) {
          cb.checked = selectAllCheckbox.checked;
        }
      });
      updateBatchActions();
    });
  }

  rowCheckboxes.forEach(cb => {
    cb.addEventListener('change', updateBatchActions);
  });

  // Click row to select
  {{if .RowSelector.Click}}
  table.querySelectorAll('tbody tr').forEach(row => {
    row.addEventListener('click', function(e) {
      if (e.target.tagName !== 'INPUT' && e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
        const checkbox = row.querySelector('.row-checkbox');
        if (checkbox && !checkbox.disabled) {
          checkbox.checked = !checkbox.checked;
          updateBatchActions();
        }
      }
    });
  });
  {{end}}

  // AJAX batch action handling
  const batchForms = document.querySelectorAll('.batch-action-form[data-ajax="true"]');
  batchForms.forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const confirmMsg = form.dataset.confirm;
      if (confirmMsg && !confirm(confirmMsg)) {
        return;
      }
      const formData = new FormData(form);
      const ids = formData.get('_ids');
      if (!ids) {
        alert('No items selected');
        return;
      }
      fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(r => r.json())
      .then(result => {
        if (result.success) {
          if (result.script) {
            eval(result.script);
          }
          location.reload();
        } else {
          alert(result.message || 'Operation failed');
        }
      })
      .catch(err => {
        alert('Error: ' + err.message);
      });
    });
  });
})();
</script>
{{end}}

{{if or .EnableDialogCreate .EnableDialogEdit}}
<script>
(function() {
  // Dialog form handling
  document.querySelectorAll('[data-dialog="true"]').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const url = this.href;
      const width = this.dataset.dialogWidth || '700px';
      const height = this.dataset.dialogHeight || '670px';
      openDialog(url, width, height);
    });
  });

  function openDialog(url, width, height) {
    // Create modal
    const modal = document.createElement('div');
    modal.className = 'modal-wrapper is-open';
    modal.innerHTML = `
      <div class="modal-overlay" onclick="closeDialog(this.parentNode)"></div>
      <div class="modal-dialog" style="width: ${width}; height: ${height};">
        <div class="modal-header">
          <h4 class="modal-title">Form</h4>
          <button class="modal-close" onclick="closeDialog(this.closest('.modal-wrapper'))">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <div class="modal-body">
          <div class="modal-loading">
            <div class="spinner"></div>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);

    // Load content
    fetch(url, {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.text())
    .then(html => {
      modal.querySelector('.modal-body').innerHTML = html;
      // Handle form submission
      const form = modal.querySelector('form');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          const formData = new FormData(form);
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
          })
          .then(r => r.json())
          .then(result => {
            if (result.success) {
              if (result.script) {
                eval(result.script);
              }
              closeDialog(modal);
              location.reload();
            } else {
              alert(result.message);
            }
          });
        });
      }
    });

    window.closeDialog = function(modal) {
      if (modal) modal.remove();
    };
  }
})();
</script>
{{end}}

{{/* Custom Tool Scripts */}}
{{range .Tools}}
{{if .Script}}<script>{{safeHTML .Script}}</script>{{end}}
{{end}}
{{end}}

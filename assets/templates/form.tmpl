function openIconPicker(fieldName) {
  currentIconField = fieldName;
  let modal = document.getElementById('icon-picker-modal');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'icon-picker-modal';
    modal.className = 'icon-modal';
    modal.innerHTML =
      '<div class="icon-modal-content">' +
        '<div class="icon-modal-header">' +
          '<span class="icon-modal-title">Choose Icon</span>' +
          '<button type="button" class="icon-modal-close" onclick="closeIconPicker()">' +
            '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
          '</button>' +
        '</div>' +
        '<div class="icon-modal-body">' +
          '<div class="icon-grid" id="icon-grid"></div>' +
        '</div>' +
      '</div>';
    document.body.appendChild(modal);

    // Build icon grid
    const grid = document.getElementById('icon-grid');
    commonIcons.forEach(function(iconSvg, idx) {
      const item = document.createElement('div');
      item.className = 'icon-item';
      item.innerHTML = iconSvg;
      item.onclick = function() {
        selectIcon(iconSvg);
      };
      grid.appendChild(item);
    });
  }
  modal.classList.add('is-open');
}

function closeIconPicker() {
  const modal = document.getElementById('icon-picker-modal');
  if (modal) {
    modal.classList.remove('is-open');
  }
}

function selectIcon(svg) {
  if (currentIconField) {
    const input = document.querySelector('input[name="' + currentIconField + '"]');
    const preview = document.getElementById('icon-preview-' + currentIconField);
    if (input) {
      input.value = svg;
    }
    if (preview) {
      preview.innerHTML = svg;
    }
  }
  closeIconPicker();
}

// Close modal when clicking outside
document.addEventListener('click', function(e) {
  const modal = document.getElementById('icon-picker-modal');
  if (modal && modal.classList.contains('is-open') && e.target === modal) {
    closeIconPicker();
  }
  const stModal = document.getElementById('selecttable-modal');
  if (stModal && stModal.classList.contains('is-open') && e.target === stModal) {
    stModal.classList.remove('is-open');
  }
});

// Markdown Editor Helper
function insertMarkdown(fieldName, prefix, suffix) {
  const textarea = document.getElementById('markdown-' + fieldName);
  if (!textarea) return;

  const start = textarea.selectionStart;
  const end = textarea.selectionEnd;
  const text = textarea.value;
  const selected = text.substring(start, end);

  textarea.value = text.substring(0, start) + prefix + selected + suffix + text.substring(end);

  // Restore cursor position
  const newCursor = start + prefix.length + selected.length;
  textarea.setSelectionRange(newCursor, newCursor);
  textarea.focus();
}

// Autocomplete functionality
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.autocomplete-input').forEach(function(input) {
    const url = input.getAttribute('data-url');
    if (!url) return;

    const dropdownId = 'dropdown-' + input.name;
    let timeout;

    input.addEventListener('input', function() {
      clearTimeout(timeout);
      const query = this.value;

      if (query.length < 1) {
        document.getElementById(dropdownId).classList.remove('is-open');
        return;
      }

      timeout = setTimeout(function() {
        fetch(url + '?q=' + encodeURIComponent(query))
          .then(function(response) { return response.json(); })
          .then(function(data) {
            const dropdown = document.getElementById(dropdownId);
            dropdown.innerHTML = '';

            if (data && data.length > 0) {
              data.forEach(function(item) {
                const div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.textContent = item.text || item.name || item;
                div.onclick = function() {
                  input.value = item.text || item.name || item;
                  dropdown.classList.remove('is-open');
                };
                dropdown.appendChild(div);
              });
              dropdown.classList.add('is-open');
            } else {
              dropdown.classList.remove('is-open');
            }
          })
          .catch(function() {
            document.getElementById(dropdownId).classList.remove('is-open');
          });
      }, 300);
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
      if (!input.contains(e.target)) {
        document.getElementById(dropdownId).classList.remove('is-open');
      }
    });

    // Handle keyboard navigation
    input.addEventListener('keydown', function(e) {
      const dropdown = document.getElementById(dropdownId);
      const items = dropdown.querySelectorAll('.autocomplete-item');
      const selected = dropdown.querySelector('.autocomplete-item.is-selected');

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!selected) {
          items[0] && items[0].classList.add('is-selected');
        } else {
          selected.classList.remove('is-selected');
          const next = selected.nextElementSibling;
          if (next) {
            next.classList.add('is-selected');
          } else {
            items[0] && items[0].classList.add('is-selected');
          }
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (selected) {
          selected.classList.remove('is-selected');
          const prev = selected.previousElementSibling;
          if (prev) {
            prev.classList.add('is-selected');
          } else {
            items[items.length - 1] && items[items.length - 1].classList.add('is-selected');
          }
        }
      } else if (e.key === 'Enter' && selected) {
        e.preventDefault();
        selected.click();
      } else if (e.key === 'Escape') {
        dropdown.classList.remove('is-open');
      }
    });
  });
});

// Mobile input mask (simple implementation)
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('input[data-mask]').forEach(function(input) {
    const mask = input.getAttribute('data-mask');
    if (!mask) return;

    input.addEventListener('input', function(e) {
      let value = this.value.replace(/\D/g, '');
      let formatted = '';
      let valueIndex = 0;

      for (let i = 0; i < mask.length && valueIndex < value.length; i++) {
        if (mask[i] === '9') {
          formatted += value[valueIndex];
          valueIndex++;
        } else {
          formatted += mask[i];
          if (valueIndex <= value.length) {
            // Add separator if needed
          }
        }
      }

      this.value = formatted;
    });
  });
});

// Image preview for multiple uploads
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.multiple-image-input').forEach(function(input) {
    input.addEventListener('change', function(e) {
      const wrapper = this.closest('.multiple-upload-wrapper');
      const grid = wrapper.querySelector('.multiple-preview-grid');
      if (!grid) return;

      Array.from(this.files).forEach(function(file) {
        if (!file.type.startsWith('image/')) return;

        const reader = new FileReader();
        reader.onload = function(e) {
          const div = document.createElement('div');
          div.className = 'preview-item';
          div.innerHTML = '<img src="' + e.target.result + '" alt="">' +
            '<button type="button" class="preview-remove" onclick="this.parentElement.remove()">×</button>';
          grid.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    });
  });
});

// SelectTable functionality
let currentSelectTableField = null;

function openSelectTable(fieldName, url) {
  currentSelectTableField = fieldName;
  let modal = document.getElementById('selecttable-modal');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'selecttable-modal';
    modal.className = 'selecttable-modal';
    modal.innerHTML =
      '<div class="selecttable-modal-content">' +
        '<div class="selecttable-modal-header">' +
          '<span class="selecttable-modal-title">Select Item</span>' +
          '<button type="button" class="selecttable-modal-close" onclick="closeSelectTable()">' +
            '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
          '</button>' +
        '</div>' +
        '<div class="selecttable-modal-body" id="selecttable-modal-body">' +
          '<p>Loading...</p>' +
        '</div>' +
      '</div>';
    document.body.appendChild(modal);
  }
  modal.classList.add('is-open');

  // Load data from URL
  if (url) {
    fetch(url)
      .then(function(response) { return response.json(); })
      .then(function(data) {
        renderSelectTable(data);
      })
      .catch(function() {
        document.getElementById('selecttable-modal-body').innerHTML = '<p>Error loading data</p>';
      });
  }
}

function closeSelectTable() {
  const modal = document.getElementById('selecttable-modal');
  if (modal) {
    modal.classList.remove('is-open');
  }
}

function renderSelectTable(data) {
  const body = document.getElementById('selecttable-modal-body');
  if (!data || data.length === 0) {
    body.innerHTML = '<p>No data available</p>';
    return;
  }

  let html = '<table class="admin-table"><thead><tr>';
  const keys = Object.keys(data[0]);
  keys.forEach(function(key) {
    html += '<th>' + key + '</th>';
  });
  html += '<th>Action</th></tr></thead><tbody>';

  data.forEach(function(item) {
    html += '<tr>';
    keys.forEach(function(key) {
      html += '<td>' + item[key] + '</td>';
    });
    html += '<td><button type="button" class="btn btn-primary btn-sm" onclick="selectTableItem(' + item.id + ', \'' + (item.name || item.title || item.id) + '\')">Select</button></td>';
    html += '</tr>';
  });

  html += '</tbody></table>';
  body.innerHTML = html;
}

function selectTableItem(id, display) {
  if (currentSelectTableField) {
    const valueInput = document.getElementById('selecttable-value-' + currentSelectTableField);
    const displayDiv = document.getElementById('selecttable-display-' + currentSelectTableField);
    if (valueInput) valueInput.value = id;
    if (displayDiv) displayDiv.innerHTML = '<span class="selecttable-selected">' + display + '</span>';
  }
  closeSelectTable();
}

// Tree checkbox cascade
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.tree-wrapper').forEach(function(wrapper) {
    wrapper.addEventListener('change', function(e) {
      if (e.target.type === 'checkbox') {
        const node = e.target.closest('.tree-node');
        const children = node.querySelectorAll('.tree-children input[type="checkbox"]');
        children.forEach(function(child) {
          child.checked = e.target.checked;
        });
      }
    });
  });
});

// Table form add row
function addTableRow(fieldName) {
  const wrapper = document.querySelector('[data-field="' + fieldName + '"].table-form-wrapper');
  if (!wrapper) return;

  const tbody = document.getElementById('table-body-' + fieldName);
  const rowCount = tbody.querySelectorAll('tr').length;

  // Get template from first row or create basic structure
  const templateRow = tbody.querySelector('tr');
  if (templateRow) {
    const newRow = templateRow.cloneNode(true);
    newRow.querySelectorAll('input, select').forEach(function(input) {
      input.value = '';
      const name = input.name;
      input.name = name.replace(/\[\d+\]/, '[' + rowCount + ']');
    });
    tbody.appendChild(newRow);
  }
}

// HasMany add item
function addHasManyItem(fieldName) {
  const wrapper = document.querySelector('[data-field="' + fieldName + '"].hasmany-wrapper');
  if (!wrapper) return;

  const items = document.getElementById('hasmany-items-' + fieldName);
  const itemCount = items.querySelectorAll('.hasmany-item').length;
  const templateItem = items.querySelector('.hasmany-item');

  if (templateItem) {
    const newItem = templateItem.cloneNode(true);
    newItem.querySelectorAll('input, select, textarea').forEach(function(input) {
      if (input.type !== 'hidden') {
        input.value = '';
      }
      const name = input.name;
      input.name = name.replace(/\[\d+\]/, '[' + itemCount + ']');
    });
    newItem.querySelector('.hasmany-item-title').textContent = 'Item ' + (itemCount + 1);
    items.appendChild(newItem);
  }
}
</script>

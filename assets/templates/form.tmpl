{{define "form"}}
<div class="panel">
  <div class="panel-head">
    <div>
      <h2 class="panel-title">{{.Title}}</h2>
      {{if .Description}}<p class="panel-copy">{{.Description}}</p>{{end}}
    </div>
    <a class="btn btn-secondary" href="{{.BackURL}}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Back
    </a>
  </div>

  {{if .Message}}
  <div class="panel-body">
    <div class="flash flash-error">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      {{.Message}}
    </div>
  </div>
  {{end}}

  <form class="panel-body" method="post" action="{{.Action}}" enctype="{{.Enctype}}">
    {{if eq .Method "PUT"}}
    <input type="hidden" name="_method" value="PUT">
    {{end}}
    <input type="hidden" name="_csrf" value="{{.CSRF}}">

    <div class="stack">
      {{range .Fields}}
        {{if eq .Type "hidden"}}
        <input type="hidden" name="{{.Name}}" value="{{.Value}}">

        {{else if eq .Type "display"}}
        <div class="field">
          <label>{{.Label}}</label>
          <div style="padding: 0.75rem 1rem; background: var(--color-bg-hover); border: 1px solid var(--color-border); border-radius: 0.375rem; color: var(--color-text-primary); font-size: 0.875rem;">
            {{.Value}}
          </div>
        </div>

        {{else if eq .Type "textarea"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <textarea name="{{.Name}}" placeholder="{{.Placeholder}}" {{if .Error}}class="error"{{end}}>{{.Value}}</textarea>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "select"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <select name="{{.Name}}" {{if .Error}}class="error"{{end}}>
            {{range .Options}}
            <option value="{{.Value}}" {{if .Selected}}selected{{end}}>{{.Label}}</option>
            {{end}}
          </select>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "radio"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="radio-group {{if .IsInline}}inline{{end}}">
            {{range .Options}}
            <label class="radio-label">
              <input type="radio" name="{{$.Name}}" value="{{.Value}}" {{if .Selected}}checked{{end}}>
              <span>{{.Label}}</span>
            </label>
            {{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "checkbox"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="checkbox-group {{if .IsInline}}inline{{end}}">
            {{range .Options}}
            <label class="checkbox-label">
              <input type="checkbox" name="{{$.Name}}" value="{{.Value}}" {{if .Selected}}checked{{end}}>
              <span>{{.Label}}</span>
            </label>
            {{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "editor"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <textarea name="{{.Name}}" id="editor-{{.Name}}" class="editor-textarea" {{if .EditorHeight}}style="height: {{.EditorHeight}}px;"{{end}} {{if .Error}}class="error"{{end}}>{{.Value}}</textarea>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "color"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="color-picker-wrapper">
            <input type="color" name="{{.Name}}" value="{{.Value}}" {{if .Error}}class="error"{{end}}>
            <input type="text" name="{{.Name}}_text" value="{{.Value}}" class="color-text-input" placeholder="#3C50E0">
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "range"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="range-wrapper">
            <input type="range" name="{{.Name}}" value="{{.Value}}" {{if .MinVal}}min="{{.MinVal}}"{{end}} {{if .MaxVal}}max="{{.MaxVal}}"{{end}} {{if .StepVal}}step="{{.StepVal}}"{{end}} class="range-input">
            <span class="range-value">{{.Value}}</span>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "rate"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="rate-wrapper" data-name="{{.Name}}">
            {{range $i := iterate 1 6}}
            <input type="radio" name="{{$.Name}}" value="{{$i}}" id="{{$.Name}}-{{$i}}" {{if eq $.Value (print $i)}}checked{{end}}>
            <label for="{{$.Name}}-{{$i}}" class="rate-star">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </label>
            {{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "currency"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="currency-wrapper">
            <span class="currency-symbol">{{if .CurrencySymbol}}{{.CurrencySymbol}}{{else}}¥{{end}}</span>
            <input type="number" name="{{.Name}}" value="{{.Value}}" placeholder="0.00" step="0.01" {{if .Error}}class="error"{{end}}>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "keyvalue"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="keyvalue-wrapper" data-name="{{.Name}}">
            {{range .KeyValueRows}}
            <div class="keyvalue-row">
              <input type="text" name="{{.FieldName}}[{{.Index}}][key]" value="{{.Key}}" placeholder="{{if .KeyPlaceholder}}{{.KeyPlaceholder}}{{else}}Key{{end}}">
              <input type="text" name="{{.FieldName}}[{{.Index}}][value]" value="{{.Value}}" placeholder="{{if .ValuePlaceholder}}{{.ValuePlaceholder}}{{else}}Value{{end}}">
              <button type="button" class="keyvalue-remove" onclick="this.parentElement.remove()">×</button>
            </div>
            {{end}}
            <button type="button" class="btn btn-secondary btn-sm keyvalue-add" data-field="{{.Name}}">+ 添加</button>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "multiselect"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <select name="{{.Name}}" multiple size="{{if gt (len .Options) 6}}6{{else if gt (len .Options) 0}}{{len .Options}}{{else}}4{{end}}" {{if .Error}}class="error"{{end}}>
            {{range .Options}}
            <option value="{{.Value}}" {{if .Selected}}selected{{end}}>{{.Label}}</option>
            {{end}}
          </select>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "switch"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <label style="position: relative; display: inline-flex; height: 1.5rem; width: 2.75rem; cursor: pointer;">
              <input name="{{.Name}}" type="checkbox" value="1" {{if .Checked}}checked{{end}} style="position: absolute; width: 0; height: 0; opacity: 0;">
              <span style="display: inline-flex; height: 1.5rem; width: 2.75rem; align-items: center; border-radius: 9999px; background: var(--color-border); transition: all 0.2s;" class="switch-bg">
                <span style="display: inline-block; height: 1.125rem; width: 1.125rem; border-radius: 50%; background: white; transition: transform 0.2s; margin-left: 0.1875rem; transform: translateX(0);" class="switch-dot"></span>
              </span>
            </label>
            <span style="font-size: 0.875rem; color: var(--color-text-secondary);">{{if .Checked}}Enabled{{else}}Disabled{{end}}</span>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "tags"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="text" value="{{.Value}}" placeholder="{{if .Placeholder}}{{.Placeholder}}{{else}}e.g. go, admin, tailwind{{end}}" {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "daterange"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
            <input name="{{.Name}}" type="date" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .Error}}class="error"{{end}}>
            <input name="{{.SecondName}}" type="date" value="{{.SecondValue}}" placeholder="{{.SecondPlaceholder}}" {{if .Error}}class="error"{{end}}>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "repeater"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          {{$field := .}}
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            {{range $field.RepeaterRows}}
            {{$row := .}}
            <div style="padding: 1rem; border: 1px solid var(--color-border); border-radius: 0.5rem; background: var(--color-bg-hover);">
              <div style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                {{range $field.RepeaterFields}}
                  {{if eq .Type "hidden"}}
                  <input name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" type="hidden" value="{{index $row.Values .Name}}">
                  {{else if eq .Type "textarea"}}
                  <textarea name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" placeholder="{{.Placeholder}}" style="min-height: 80px;">{{index $row.Values .Name}}</textarea>
                  {{else if eq .Type "select"}}
                  <select name="{{$field.Name}}.{{$row.Index}}.{{.Name}}">
                    {{range .Options}}
                    <option value="{{.Value}}" {{if eq (index $row.Values $.Name) .Value}}selected{{end}}>{{.Label}}</option>
                    {{end}}
                  </select>
                  {{else if eq .Type "radio"}}
                  <div class="radio-group {{if .IsInline}}inline{{end}}">
                    {{range .Options}}
                    <label class="radio-label">
                      <input type="radio" name="{{$field.Name}}.{{$row.Index}}.{{$.Name}}" value="{{.Value}}" {{if eq (index $row.Values $.Name) .Value}}checked{{end}}>
                      <span>{{.Label}}</span>
                    </label>
                    {{end}}
                  </div>
                  {{else if eq .Type "checkbox"}}
                  <div class="checkbox-group {{if .IsInline}}inline{{end}}">
                    {{range .Options}}
                    <label class="checkbox-label">
                      <input type="checkbox" name="{{$field.Name}}.{{$row.Index}}.{{$.Name}}" value="{{.Value}}" {{if eq (index $row.Values $.Name) .Value}}checked{{end}}>
                      <span>{{.Label}}</span>
                    </label>
                    {{end}}
                  </div>
                  {{else if eq .Type "switch"}}
                  <label style="position: relative; display: inline-flex; height: 1.5rem; width: 2.75rem; cursor: pointer;">
                    <input name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" type="checkbox" value="1" {{if eq (index $row.Values .Name) "1"}}checked{{end}} style="position: absolute; width: 0; height: 0; opacity: 0;">
                    <span style="display: inline-flex; height: 1.5rem; width: 2.75rem; align-items: center; border-radius: 9999px; background: var(--color-border); transition: all 0.2s;" class="switch-bg">
                      <span style="display: inline-block; height: 1.125rem; width: 1.125rem; border-radius: 50%; background: white; transition: transform 0.2s; margin-left: 0.1875rem; transform: translateX(0);" class="switch-dot"></span>
                    </span>
                  </label>
                  {{else if eq .Type "color"}}
                  <div class="color-picker-wrapper">
                    <input type="color" name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" value="{{index $row.Values .Name}}">
                    <input type="text" value="{{index $row.Values .Name}}" class="color-text-input" placeholder="#3C50E0">
                  </div>
                  {{else if eq .Type "number"}}
                  <input name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" type="number" value="{{index $row.Values .Name}}" {{if .MinVal}}min="{{.MinVal}}"{{end}} {{if .MaxVal}}max="{{.MaxVal}}"{{end}} {{if .StepVal}}step="{{.StepVal}}"{{end}} placeholder="{{.Placeholder}}">
                  {{else if eq .Type "time"}}
                  <input name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" type="time" value="{{index $row.Values .Name}}" placeholder="{{.Placeholder}}">
                  {{else}}
                  <input name="{{$field.Name}}.{{$row.Index}}.{{.Name}}" type="{{if .Type}}{{.Type}}{{else}}text{{end}}" value="{{index $row.Values .Name}}" placeholder="{{.Placeholder}}">
                  {{end}}
                {{end}}
              </div>
            </div>
            {{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "file"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="file" {{if .Multiple}}multiple{{end}} {{if .Error}}class="error"{{end}} style="padding: 0.5rem 0;">
          {{if .FileURLs}}
            <div style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem;">
              {{range .FileURLs}}
              <a href="{{.}}" target="_blank" rel="noreferrer" style="font-size: 0.875rem; color: var(--color-primary); text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                {{.}}
              </a>
              {{end}}
            </div>
          {{else if .FileURL}}
            <div style="margin-top: 0.75rem; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 0.5rem; background: var(--color-bg-hover);">
              {{if .IsImage}}<img src="{{.FileURL}}" alt="{{.Label}}" style="max-width: 200px; border-radius: 0.375rem; margin-bottom: 0.5rem;">{{end}}
              <a href="{{.FileURL}}" target="_blank" rel="noreferrer" style="font-size: 0.875rem; color: var(--color-primary); text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                {{.FileURL}}
              </a>
            </div>
          {{end}}
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "number"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="number" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .MinVal}}min="{{.MinVal}}"{{end}} {{if .MaxVal}}max="{{.MaxVal}}"{{end}} {{if .StepVal}}step="{{.StepVal}}"{{end}} {{if .Readonly}}readonly style="background: var(--color-bg-hover);"{{end}} {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "time"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="time" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .Readonly}}readonly style="background: var(--color-bg-hover);"{{end}} {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "icon"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="icon-picker-wrapper">
            <input name="{{.Name}}" type="text" value="{{.Value}}" placeholder="e.g. <svg...> or emoji" class="icon-input" {{if .Error}}class="error"{{end}}>
            <button type="button" class="btn btn-secondary btn-sm" onclick="openIconPicker('{{.Name}}')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              Choose
            </button>
          </div>
          <div class="icon-preview" id="icon-preview-{{.Name}}">
            {{if .Value}}{{safeHTML .Value}}{{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "ip"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="text" value="{{.Value}}" placeholder="{{.Placeholder}}" pattern="^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$" {{if .Readonly}}readonly style="background: var(--color-bg-hover);"{{end}} {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "mobile"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="tel" value="{{.Value}}" placeholder="{{if .Placeholder}}{{.Placeholder}}{{else}}138 8888 8888{{end}}" {{if .MaskFormat}}data-mask="{{.MaskFormat}}"{{end}} {{if .Readonly}}readonly style="background: var(--color-bg-hover);"{{end}} {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "timerange"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
            <input name="{{.Name}}" type="time" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .Error}}class="error"{{end}}>
            <input name="{{.SecondName}}" type="time" value="{{.SecondValue}}" placeholder="{{.SecondPlaceholder}}" {{if .Error}}class="error"{{end}}>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "datetimerange"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
            <input name="{{.Name}}" type="datetime-local" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .Error}}class="error"{{end}}>
            <input name="{{.SecondName}}" type="datetime-local" value="{{.SecondValue}}" placeholder="{{.SecondPlaceholder}}" {{if .Error}}class="error"{{end}}>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "image"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="image-upload-wrapper">
            <input name="{{.Name}}" type="file" accept="image/*" class="image-input" {{if .Error}}class="error"{{end}}>
            {{if .FileURL}}
            <div class="image-preview">
              <img src="{{.FileURL}}" alt="{{.Label}}">
              <button type="button" class="image-remove" onclick="removeImage(this)">×</button>
            </div>
            {{end}}
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "multipleimage"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="multiple-upload-wrapper">
            <input name="{{.Name}}" type="file" accept="image/*" multiple class="multiple-image-input" {{if .Error}}class="error"{{end}}>
            <div class="multiple-preview-grid" id="preview-{{.Name}}">
              {{range .FileURLs}}
              <div class="preview-item">
                <img src="{{.}}" alt="">
                <button type="button" class="preview-remove" onclick="this.parentElement.remove()">×</button>
              </div>
              {{end}}
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "multiplefile"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="multiple-upload-wrapper">
            <input name="{{.Name}}" type="file" multiple class="multiple-file-input" {{if .Error}}class="error"{{end}}>
            <div class="file-list" id="file-list-{{.Name}}">
              {{range .FileURLs}}
              <div class="file-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span>{{.}}</span>
                <button type="button" class="file-remove" onclick="this.parentElement.remove()">×</button>
              </div>
              {{end}}
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "markdown"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="markdown-editor-wrapper">
            <textarea name="{{.Name}}" id="markdown-{{.Name}}" class="markdown-textarea" {{if .EditorHeight}}style="height: {{.EditorHeight}}px;"{{end}} {{if .Error}}class="error"{{end}}>{{.Value}}</textarea>
            <div class="markdown-toolbar">
              <button type="button" onclick="insertMarkdown('{{.Name}}', '**', '**')">Bold</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '*', '*')">Italic</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '# ', '')">H1</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '## ', '')">H2</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '- ', '')">List</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '[', '](url)')">Link</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '![', '](image-url)')">Image</button>
              <button type="button" onclick="insertMarkdown('{{.Name}}', '```\n', '\n```')">Code</button>
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "slider"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="slider-wrapper">
            <input type="range" name="{{.Name}}" value="{{.Value}}" min="{{if .SliderMin}}{{.SliderMin}}{{else}}0{{end}}" max="{{if .SliderMax}}{{.SliderMax}}{{else}}100{{end}}" step="{{if .SliderStep}}{{.SliderStep}}{{else}}1{{end}}" class="slider-input" oninput="document.getElementById('slider-value-{{.Name}}').textContent = this.value + '{{if .SliderPostfix}}{{.SliderPostfix}}{{end}}'">
            <span class="slider-value" id="slider-value-{{.Name}}">{{.Value}}{{if .SliderPostfix}}{{.SliderPostfix}}{{end}}</span>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "autocomplete"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="autocomplete-wrapper">
            <input name="{{.Name}}" type="text" value="{{.Value}}" placeholder="{{.Placeholder}}" class="autocomplete-input" {{if .AutocompleteURL}}data-url="{{.AutocompleteURL}}"{{end}} {{if .Error}}class="error"{{end}} autocomplete="off">
            <div class="autocomplete-dropdown" id="dropdown-{{.Name}}"></div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "listbox"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="listbox-wrapper">
            <select name="{{.Name}}" multiple class="listbox-select" {{if .Error}}class="error"{{end}}>
              {{range .Options}}
              <option value="{{.Value}}" {{if .Selected}}selected{{end}}>{{.Label}}</option>
              {{end}}
            </select>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "map"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="map-wrapper" data-provider="{{if .MapProvider}}{{.MapProvider}}{{else}}tencent{{end}}">
            <div class="map-container" id="map-{{.Name}}"></div>
            <div class="map-coordinates">
              <input type="hidden" name="{{.Name}}" value="{{.Value}}" id="map-lat-{{.Name}}">
              <input type="hidden" name="{{.SecondName}}" value="{{.SecondValue}}" id="map-lng-{{.Name}}">
              <div class="map-info">
                <span>Latitude: {{.Value}}</span>
                <span>Longitude: {{.SecondValue}}</span>
              </div>
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "tree"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="tree-wrapper" id="tree-{{.Name}}">
            <div class="tree-container">
              {{range .TreeNodes}}
              <div class="tree-node" data-id="{{.ID}}" data-parent="{{.ParentID}}">
                <label class="tree-label">
                  <input type="checkbox" name="{{$.Name}}[]" value="{{.ID}}" {{if .Selected}}checked{{end}}>
                  <span>{{.Title}}</span>
                </label>
                {{if .Children}}
                <div class="tree-children">
                  {{range .Children}}
                  <div class="tree-node" data-id="{{.ID}}" data-parent="{{.ParentID}}">
                    <label class="tree-label">
                      <input type="checkbox" name="{{$.Name}}[]" value="{{.ID}}" {{if .Selected}}checked{{end}}>
                      <span>{{.Title}}</span>
                    </label>
                  </div>
                  {{end}}
                </div>
                {{end}}
              </div>
              {{end}}
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "selecttable"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="selecttable-wrapper">
            <input type="hidden" name="{{.Name}}" value="{{.Value}}" id="selecttable-value-{{.Name}}">
            <div class="selecttable-display" id="selecttable-display-{{.Name}}">
              {{if .Value}}<span class="selecttable-selected">{{.Value}}</span>{{else}}<span class="selecttable-placeholder">Click to select...</span>{{end}}
            </div>
            <button type="button" class="btn btn-secondary btn-sm" onclick="openSelectTable('{{.Name}}', '{{if .SelectTableURL}}{{.SelectTableURL}}{{end}}')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="9" y1="21" x2="9" y2="9"/>
              </svg>
              Select
            </button>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "table"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="table-form-wrapper" data-field="{{.Name}}">
            <table class="table-form">
              <thead>
                <tr>
                  {{range .NestedFields}}
                  <th>{{.Label}}</th>
                  {{end}}
                  <th class="table-form-actions">Actions</th>
                </tr>
              </thead>
              <tbody id="table-body-{{.Name}}">
                {{range .TableRows}}
                <tr class="table-row">
                  {{range $.NestedFields}}
                  <td>
                    {{if eq .Type "text"}}
                    <input type="text" name="{{$.FieldName}}[{{.RowIndex}}][{{.Name}}]" value="{{index .RowValues .Name}}" placeholder="{{.Placeholder}}">
                    {{else if eq .Type "number"}}
                    <input type="number" name="{{$.FieldName}}[{{.RowIndex}}][{{.Name}}]" value="{{index .RowValues .Name}}" placeholder="{{.Placeholder}}">
                    {{else if eq .Type "select"}}
                    <select name="{{$.FieldName}}[{{.RowIndex}}][{{.Name}}]">
                      {{range .Options}}
                      <option value="{{.Value}}" {{if eq (index $.RowValues $.Name) .Value}}selected{{end}}>{{.Label}}</option>
                      {{end}}
                    </select>
                    {{else if eq .Type "date"}}
                    <input type="date" name="{{$.FieldName}}[{{.RowIndex}}][{{.Name}}]" value="{{index .RowValues .Name}}">
                    {{end}}
                  </td>
                  {{end}}
                  <td class="table-form-actions">
                    <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">Delete</button>
                  </td>
                </tr>
                {{end}}
              </tbody>
            </table>
            <button type="button" class="btn btn-secondary btn-sm" onclick="addTableRow('{{.Name}}')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Add Row
            </button>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "hasmany"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="hasmany-wrapper" data-field="{{.Name}}">
            <div class="hasmany-items" id="hasmany-items-{{.Name}}">
              {{range .HasManyRows}}
              <div class="hasmany-item">
                <div class="hasmany-item-header">
                  <span class="hasmany-item-title">{{.ItemLabel}}</span>
                  <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.hasmany-item').remove()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                    </svg>
                    Delete
                  </button>
                </div>
                <div class="hasmany-item-body">
                  {{range $.NestedFields}}
                  <div class="hasmany-field">
                    <label>{{.Label}}</label>
                    {{if eq .Type "text"}}
                    <input type="text" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="{{index .ItemValues .Name}}" placeholder="{{.Placeholder}}">
                    {{else if eq .Type "number"}}
                    <input type="number" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="{{index .ItemValues .Name}}" placeholder="{{.Placeholder}}">
                    {{else if eq .Type "textarea"}}
                    <textarea name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" placeholder="{{.Placeholder}}">{{index .ItemValues .Name}}</textarea>
                    {{else if eq .Type "select"}}
                    <select name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]">
                      {{range .Options}}
                      <option value="{{.Value}}" {{if eq (index $.ItemValues $.Name) .Value}}selected{{end}}>{{.Label}}</option>
                      {{end}}
                    </select>
                    {{else if eq .Type "date"}}
                    <input type="date" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="{{index .ItemValues .Name}}">
                    {{else if eq .Type "datetime-local"}}
                    <input type="datetime-local" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="{{index .ItemValues .Name}}">
                    {{else if eq .Type "switch"}}
                    <label class="switch-label">
                      <input type="checkbox" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="1" {{if eq (index .ItemValues .Name) "1"}}checked{{end}}>
                      <span class="switch-bg"><span class="switch-dot"></span></span>
                    </label>
                    {{else if eq .Type "hidden"}}
                    <input type="hidden" name="{{$.FieldName}}[{{.ItemIndex}}][{{.Name}}]" value="{{index .ItemValues .Name}}">
                    {{end}}
                  </div>
                  {{end}}
                </div>
              </div>
              {{end}}
            </div>
            <button type="button" class="btn btn-primary btn-sm" onclick="addHasManyItem('{{.Name}}')">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Add {{.HasManyLabel}}
            </button>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "embeds"}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <div class="embeds-wrapper">
            <div class="embeds-fields">
              {{range .NestedFields}}
              <div class="embeds-field">
                <label>{{.Label}}</label>
                {{if eq .Type "text"}}
                <input type="text" name="{{$.Name}}.{{.Name}}" value="{{index $.EmbedsValues .Name}}" placeholder="{{.Placeholder}}">
                {{else if eq .Type "number"}}
                <input type="number" name="{{$.Name}}.{{.Name}}" value="{{index $.EmbedsValues .Name}}" placeholder="{{.Placeholder}}">
                {{else if eq .Type "textarea"}}
                <textarea name="{{$.Name}}.{{.Name}}" placeholder="{{.Placeholder}}">{{index $.EmbedsValues .Name}}</textarea>
                {{else if eq .Type "select"}}
                <select name="{{$.Name}}.{{.Name}}">
                  {{range .Options}}
                  <option value="{{.Value}}" {{if eq (index $.EmbedsValues $.Name) .Value}}selected{{end}}>{{.Label}}</option>
                  {{end}}
                </select>
                {{else if eq .Type "date"}}
                <input type="date" name="{{$.Name}}.{{.Name}}" value="{{index $.EmbedsValues .Name}}">
                {{else if eq .Type "datetime-local"}}
                <input type="datetime-local" name="{{$.Name}}.{{.Name}}" value="{{index $.EmbedsValues .Name}}">
                {{else if eq .Type "switch"}}
                <label class="switch-label">
                  <input type="checkbox" name="{{$.Name}}.{{.Name}}" value="1" {{if eq (index $.EmbedsValues .Name) "1"}}checked{{end}}>
                  <span class="switch-bg"><span class="switch-dot"></span></span>
                </label>
                {{end}}
              </div>
              {{end}}
            </div>
          </div>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>

        {{else if eq .Type "divider"}}
        <div class="form-divider">
          <hr>
        </div>

        {{else if eq .Type "html"}}
        <div class="form-html-content">
          {{safeHTML .HtmlContent}}
        </div>

        {{else}}
        <div class="field">
          <label>{{.Label}}{{if .Required}}<span class="required">*</span>{{end}}</label>
          <input name="{{.Name}}" type="{{.Type}}" value="{{.Value}}" placeholder="{{.Placeholder}}" {{if .Readonly}}readonly style="background: var(--color-bg-hover);"{{end}} {{if .Error}}class="error"{{end}}>
          {{if .Error}}<small class="form-error">{{.Error}}</small>{{end}}
          {{if .Help}}<small class="form-hint">{{.Help}}</small>{{end}}
        </div>
        {{end}}
      {{end}}

      <div style="display: flex; align-items: center; gap: 0.75rem; padding-top: 1rem; border-top: 1px solid var(--color-border);">
        <button class="btn btn-primary" type="submit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
            <polyline points="17 21 17 13 7 13 7 21"/>
            <polyline points="7 3 7 8 15 8"/>
          </svg>
          {{.SubmitLabel}}
        </button>
        <a class="btn btn-secondary" href="{{.BackURL}}">Cancel</a>
      </div>
    </div>
  </form>

  {{if .ShowDelete}}
  <div class="panel-body" style="border-top: 1px solid var(--color-border);">
    <form method="post" action="{{.DeleteAction}}" onsubmit="return confirm('Are you sure you want to delete this record? This action cannot be undone.')">
      <input type="hidden" name="_csrf" value="{{.CSRF}}">
      <button class="btn btn-danger" type="submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        </svg>
        {{.DeleteLabel}}
      </button>
    </form>
  </div>
  {{end}}
</div>

<style>
input[type="checkbox"]:checked + .switch-bg {
  background: var(--color-primary) !important;
}
input[type="checkbox"]:checked + .switch-bg .switch-dot {
  transform: translateX(1.25rem) !important;
}

/* Radio Group */
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.radio-group.inline {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 1rem;
}
.radio-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  font-size: 0.875rem;
}
.radio-label input[type="radio"] {
  width: 1rem;
  height: 1rem;
  accent-color: var(--color-primary);
}

/* Checkbox Group */
.checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.checkbox-group.inline {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 1rem;
}
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  font-size: 0.875rem;
}
.checkbox-label input[type="checkbox"] {
  width: 1rem;
  height: 1rem;
  accent-color: var(--color-primary);
}

/* Color Picker */
.color-picker-wrapper {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.color-picker-wrapper input[type="color"] {
  width: 3rem;
  height: 2.5rem;
  padding: 0.25rem;
  border: 1px solid var(--color-border);
  border-radius: 0.375rem;
  background: var(--color-bg-card);
  cursor: pointer;
}
.color-picker-wrapper .color-text-input {
  flex: 1;
  max-width: 200px;
}

/* Range Slider */
.range-wrapper {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.range-input {
  flex: 1;
  height: 0.5rem;
  -webkit-appearance: none;
  appearance: none;
  background: var(--color-border);
  border-radius: 0.25rem;
  outline: none;
}
.range-input::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 1.25rem;
  height: 1.25rem;
  background: var(--color-primary);
  border-radius: 50%;
  cursor: pointer;
}
.range-input::-moz-range-thumb {
  width: 1.25rem;
  height: 1.25rem;
  background: var(--color-primary);
  border-radius: 50%;
  cursor: pointer;
  border: none;
}
.range-value {
  min-width: 3rem;
  text-align: center;
  font-weight: 600;
  color: var(--color-primary);
}

/* Star Rating */
.rate-wrapper {
  display: flex;
  flex-direction: row-reverse;
  justify-content: flex-end;
  gap: 0.25rem;
}
.rate-wrapper input[type="radio"] {
  display: none;
}
.rate-star {
  cursor: pointer;
  color: var(--color-border);
  transition: color 0.2s;
}
.rate-star svg {
  width: 28px;
  height: 28px;
}
.rate-wrapper input[type="radio"]:checked ~ .rate-star,
.rate-wrapper input[type="radio"]:checked + .rate-star,
.rate-star:hover,
.rate-star:hover ~ .rate-star {
  color: #ffc107;
}

/* Currency Input */
.currency-wrapper {
  display: flex;
  align-items: center;
  position: relative;
}
.currency-symbol {
  position: absolute;
  left: 1rem;
  color: var(--color-text-muted);
  font-weight: 500;
}
.currency-wrapper input {
  padding-left: 2.5rem !important;
}

/* KeyValue Pairs */
.keyvalue-wrapper {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.keyvalue-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.keyvalue-row input {
  flex: 1;
}
.keyvalue-remove {
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-danger);
  color: white;
  border: none;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 1.25rem;
  line-height: 1;
}
.keyvalue-remove:hover {
  background: var(--color-danger-dark);
}
.keyvalue-add {
  align-self: flex-start;
  margin-top: 0.5rem;
}

/* Icon Picker */
.icon-picker-wrapper {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.icon-picker-wrapper .icon-input {
  flex: 1;
}
.icon-preview {
  margin-top: 0.5rem;
  padding: 0.75rem;
  border: 1px dashed var(--color-border);
  border-radius: 0.375rem;
  min-height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-preview svg {
  width: 24px;
  height: 24px;
}

/* Icon Modal */
.icon-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}
.icon-modal.is-open {
  display: flex;
}
.icon-modal-content {
  background: var(--color-bg-card);
  border-radius: 0.5rem;
  width: 90%;
  max-width: 600px;
  max-height: 80vh;
  overflow: hidden;
}
.icon-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem;
  border-bottom: 1px solid var(--color-border);
}
.icon-modal-title {
  font-weight: 600;
  font-size: 1.125rem;
}
.icon-modal-close {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.25rem;
  color: var(--color-text-muted);
}
.icon-modal-close:hover {
  color: var(--color-text-primary);
}
.icon-modal-body {
  padding: 1rem;
  max-height: 60vh;
  overflow-y: auto;
}
.icon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(48px, 1fr));
  gap: 0.5rem;
}
.icon-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-border);
  border-radius: 0.375rem;
  cursor: pointer;
  transition: all 0.2s;
}
.icon-item:hover {
  border-color: var(--color-primary);
  background: var(--color-bg-hover);
}
.icon-item svg {
  width: 20px;
  height: 20px;
}

/* Image Upload */

<script>
// KeyValue field: Add new row
function addKeyValueRow(fieldName) {
  const wrapper = document.querySelector('[data-name="' + fieldName + '"].keyvalue-wrapper');
  if (!wrapper) return;

  const rows = wrapper.querySelectorAll('.keyvalue-row');
  const newIndex = rows.length;

  const row = document.createElement('div');
  row.className = 'keyvalue-row';
  row.innerHTML =
    '<input type="text" name="' + fieldName + '[' + newIndex + '][key]" value="" placeholder="Key">' +
    '<input type="text" name="' + fieldName + '[' + newIndex + '][value]" value="" placeholder="Value">' +
    '<button type="button" class="keyvalue-remove" onclick="this.parentElement.remove()">&times;</button>';

  wrapper.insertBefore(row, wrapper.querySelector('.keyvalue-add'));
}

// Initialize KeyValue add buttons
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.keyvalue-add').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const fieldName = this.getAttribute('data-field');
      addKeyValueRow(fieldName);
    });
  });
});


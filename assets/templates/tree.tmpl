{{define "tree"}}
<div class="panel">
  <div class="panel-head">
    <div>
      <h2 class="panel-title">{{.Title}}</h2>
      {{if .Description}}<p class="panel-copy">{{.Description}}</p>{{end}}
    </div>
  </div>
  {{if .Nodes}}
  <div class="panel-body">
    <div class="tree-root">
      {{template "tree-nodes" .Nodes}}
    </div>
  </div>
  {{else}}
  <div class="panel-body">
    <div class="empty">
      <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M3 9h18"/>
        <path d="M9 3v18"/>
      </svg>
      <div class="empty-title">No records found</div>
      <div class="empty-text">{{.EmptyText}}</div>
    </div>
  </div>
  {{end}}
</div>
{{end}}

{{define "tree-nodes"}}
<ul class="tree-list">
  {{range .}}
  <li class="tree-item">
    <div class="tree-node">
      <svg class="tree-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
        <path d="M2 17l10 5 10-5"/>
        <path d="M2 12l10 5 10-5"/>
      </svg>
      <div class="tree-content">
        <a href="{{.URL}}" style="font-weight: 500; color: inherit; text-decoration: none;">{{.Title}}</a>
        {{if .Description}}<div style="font-size: 0.875rem; color: var(--color-text-muted); margin-top: 0.125rem;">{{.Description}}</div>{{end}}
      </div>
      <div class="tree-actions">
        <a href="{{.URL}}" style="color: var(--color-primary); font-size: 0.875rem; font-weight: 500; text-decoration: none; padding: 0.375rem 0.625rem; border-radius: 0.375rem; transition: all 0.2s;">
          Edit
        </a>
      </div>
    </div>
    {{if .Children}}
    <div class="tree-children">
      {{template "tree-nodes" .Children}}
    </div>
    {{end}}
  </li>
  {{end}}
</ul>
{{end}}

{{define "dashboard"}}
<!-- Stats Cards -->
<div class="card-grid">
  {{range .Cards}}
  <div class="metric-card">
    <div class="metric-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <line x1="3" y1="9" x2="21" y2="9"/>
        <line x1="9" y1="21" x2="9" y2="9"/>
      </svg>
    </div>
    <div class="metric-value">{{.Value}}</div>
    <div class="metric-label">{{.Title}}</div>
    {{if .Hint}}<div style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.5rem;">{{.Hint}}</div>{{end}}
  </div>
  {{end}}
</div>

{{if .Panels}}
<!-- Dashboard Panels -->
<div style="display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); margin-top: 1.5rem;">
  {{range .Panels}}
  <div class="panel">
    <div class="panel-head">
      <div>
        <h2 class="panel-title">{{.Title}}</h2>
        {{if .Description}}<p class="panel-copy">{{.Description}}</p>{{end}}
      </div>
      {{if .Actions}}
      <div class="actions-row">
        {{range .Actions}}
        <a class="btn {{if eq .Class "btn-primary"}}btn-primary{{else}}btn-secondary{{end}}" href="{{.URL}}">
          {{.Label}}
        </a>
        {{end}}
      </div>
      {{end}}
    </div>
    {{if .Items}}
    <div class="panel-body">
      <div style="display: flex; flex-direction: column;">
        {{range .Items}}
        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
          <div style="flex: 1; min-width: 0;">
            {{if .URL}}
            <a href="{{.URL}}" style="font-size: 0.875rem; font-weight: 500; color: var(--color-text-primary); text-decoration: none;">{{.Title}}</a>
            {{else}}
            <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-text-primary);">{{.Title}}</div>
            {{end}}
            {{if .Description}}<div style="font-size: 0.875rem; color: var(--color-text-secondary); margin-top: 0.125rem;">{{.Description}}</div>{{end}}
            {{if .Tags}}
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
              {{range .Tags}}<span class="badge badge-warning">{{.}}</span>{{end}}
            </div>
            {{end}}
          </div>
          {{if .Value}}<div style="font-size: 0.875rem; font-weight: 500; color: var(--color-text-secondary); flex-shrink: 0;">{{.Value}}</div>{{end}}
        </div>
        {{end}}
      </div>
    </div>
    {{else}}
    <div class="panel-body">
      <div class="empty empty-inline">
        <div class="empty-text">{{.EmptyText}}</div>
      </div>
    </div>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
{{end}}

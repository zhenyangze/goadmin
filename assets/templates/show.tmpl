{{define "show"}}
<div class="panel">
  <div class="panel-head">
    <div>
      <h2 class="panel-title">{{.Title}}</h2>
      {{if .Description}}<p class="panel-copy">{{.Description}}</p>{{end}}
    </div>
    <div class="actions-row">
      <a class="btn btn-secondary" href="{{.BackURL}}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back
      </a>
      <a class="btn btn-primary" href="{{.EditURL}}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
        </svg>
        Edit
      </a>
    </div>
  </div>
  <div class="panel-body">
    <div class="detail-list">
      {{range .Items}}
        {{if eq .Type "divider"}}
        <div class="detail-divider">{{.Title}}</div>
        {{else}}
        <div class="detail-row">
          <div class="detail-label">{{.Label}}</div>
          <div class="detail-value">{{safeHTML .Value}}</div>
        </div>
        {{end}}
      {{end}}
    </div>
  </div>
</div>
{{end}}
